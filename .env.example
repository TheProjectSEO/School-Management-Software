# ===========================================
# MSU School Management System - Environment Variables
# ===========================================
# IMPORTANT: Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control

# ===========================================
# Required: JWT Configuration
# ===========================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=

# ===========================================
# Required: Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Required: App Configuration
# ===========================================
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Optional: Token Expiry Configuration
# ===========================================
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d

# ===========================================
# Optional: Daily.co Video API (for live sessions)
# ===========================================
# DAILY_API_KEY=your-daily-api-key

# ===========================================
# Optional: OpenAI API (for AI features)
# ===========================================
# OPENAI_API_KEY=your-openai-api-key

# ===========================================
# Optional: Resend Email API
# ===========================================
# RESEND_API_KEY=your-resend-api-key

# ===========================================
# Optional: PayMongo Payment Gateway
# ===========================================
# PAYMONGO_SECRET_KEY=your-paymongo-secret-key
# PAYMONGO_PUBLIC_KEY=your-paymongo-public-key
# PAYMONGO_WEBHOOK_SECRET=your-webhook-secret
